# NextAuth / Auth.js
AUTH_SECRET=           # gere com: openssl rand -base64 32
AUTH_TRUST_HOST=true   # necessário fora de Vercel (local / preview custom)

# Google OAuth — crie em https://console.cloud.google.com/apis/credentials
# Redirect URI autorizado: http://localhost:3000/api/auth/callback/google (dev)
#                         https://<seu-dominio>/api/auth/callback/google (prod)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Whitelist de emails admin (separados por vírgula)
ADMIN_EMAILS=jrmildres@gmail.com

# Backend NestJS
BACKEND_URL=http://localhost:3000
BACKEND_ADMIN_SECRET=   # mesmo valor de ADMIN_SECRET no backend
